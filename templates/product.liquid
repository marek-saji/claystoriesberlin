{{ 'product.css' | asset_url | stylesheet_tag }}
{{ 'product-date-calendar.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-date-calendar.js' | asset_url }}" defer></script>

<div class="product">
  {% render 'page-title' %}

  {%- liquid
    assign mf = product.metafields.custom
    assign has_metafields = false
    if mf.duration != blank or mf.max_group_size != blank or mf.level != blank or mf.language != blank or mf.materials_included.value == true or mf.pieces_ready_in.value == true
      assign has_metafields = true
    endif
  -%}
  {%- if product.description != blank or has_metafields -%}
    <div class="product-description">
      {{ product.description }}
      {%- if has_metafields -%}
        <dl class="product-metafields">
          {%- if mf.duration != blank -%}
            <div class="product-metafields__item">
              <dt>{{ 'products.metafields.duration' | t }}</dt>
              <dd>{{ 'products.metafields.hours' | t: count: mf.duration }}</dd>
            </div>
          {%- endif -%}
          {%- if mf.max_group_size != blank -%}
            <div class="product-metafields__item">
              <dt>{{ 'products.metafields.group_size' | t }}</dt>
              <dd>{{ 'products.metafields.max_people' | t: value: mf.max_group_size }}</dd>
            </div>
          {%- endif -%}
          {%- if mf.level != blank -%}
            <div class="product-metafields__item">
              <dt>{{ 'products.metafields.level' | t }}</dt>
              <dd>{{ mf.level }}</dd>
            </div>
          {%- endif -%}
          {%- if mf.language != blank -%}
            <div class="product-metafields__item">
              <dt>{% if mf.language.value.size > 1 %}{{ 'products.metafields.languages' | t }}{% else %}{{ 'products.metafields.language' | t }}{% endif %}</dt>
              <dd>{{ mf.language.value | join: ', ' }}</dd>
            </div>
          {%- endif -%}
          {%- if mf.materials_included.value == true -%}
            <div class="product-metafields__item">
              <dt>{{ 'products.metafields.materials' | t }}</dt>
              <dd>{{ 'products.metafields.materials_included' | t }}</dd>
            </div>
          {%- endif -%}
          {%- if mf.pieces_ready_in.value == true -%}
            <div class="product-metafields__item">
              <dt>{{ 'products.metafields.pieces_ready' | t }}</dt>
              <dd>{{ 'products.metafields.pieces_ready_in' | t }}</dd>
            </div>
          {%- endif -%}
        </dl>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if product.images.size > 0 -%}
    <ul class="product-images">
      {%- for image in product.images -%}
        <li>
          {%- if forloop.first -%}
            {%- assign loading = 'eager' -%}
          {%- else -%}
            {%- assign loading = 'lazy' -%}
          {%- endif -%}
          {{- image | image_url: width: 1500 | image_tag: loading: loading, sizes: '(width > 42em): 50vw, 100vw' -}}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

  <div class="product-info">
    <p class="product-price">{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}</p>
    {%- if product.metafields.custom.price_note != blank -%}
      <p class="product-price-note">{{ product.metafields.custom.price_note | newline_to_br }}</p>
    {%- endif -%}

    {%- if product.available == false -%}
      <p class="product-not-available">{{ 'products.product.sold_out' | t }}</p>
    {%- else -%}
      <form
        action="/cart/add"
        method="post"
        id="product-form"
        class="product-form"
      >
        <fieldset role="presentation" id="product-form-fieldset" class="product-form-fieldset" disabled>
          {%- if product.variants.size > 1 or product.options contains 'Date' -%}
            {%- for option in product.options_with_values -%}
              <fieldset
                role="radiogroup"
                aria-labelledby="option-{{ option.name | handleize }}-legend"
                class="product-option-group"
              >
                {%- # Not using <legend> here, because it has magic positioning -%}
                <div
                  id="option-{{ option.name | handleize }}-legend"
                  class="product-option-group__legend"
                >
                  {{ option.name }}
                </div>
                {%- for value in option.values -%}
                  {%- if option.name == 'Date' -%}
                    {%- assign date_parts = value | split: ' - ' -%}
                    {%- assign d1date = date_parts[0] | date: format: 'date_with_weekday' -%}
                    {%- if date_parts[1] contains ' ' -%}
                      {%- assign d2date = date_parts[1] | date: format: 'date_with_weekday' -%}
                    {% else -%}
                      {%- assign d2date = d1date -%}
                    {%- endif -%}
                    {%- if option.position == 1 -%}
                      {%- assign date_variants = product.variants | where: 'option1', value -%}
                    {%- elsif option.position == 2 -%}
                      {%- assign date_variants = product.variants | where: 'option2', value -%}
                    {%- else -%}
                      {%- assign date_variants = product.variants | where: 'option3', value -%}
                    {%- endif -%}
                    {%- assign date_variants_available = date_variants | where: 'available', true -%}
                    <label class="product-option" data-date-end="{{ date_parts[1] }}">
                      <input
                        type="radio"
                        name="option-{{ option.name | handleize }}"
                        value="{{ value }}"
                        class="product-option__radio"
                        onchange="updateVariant()"
                        {% if forloop.first %}
                          checked
                        {% endif %}
                        {% if date_variants_available.size == 0 %}
                          disabled
                        {% endif %}
                      >
                      {%- if date_parts.size != 2 or d1date == date_parts[0] or d2date == date_parts[1] -%}
                        <u class="time-invalid">{{ value }}</u>
                      {%- else -%}
                        {%- assign d1time = date_parts[0] | date: format: 'time' -%}
                        {%- assign d2time = date_parts[1] | date: format: 'time' -%}
                        {%- if d1date == d2date -%}
                          <span class="time-part">{{ d1date }}</span>
                          <span class="time-part">
                            <span class="time-part">{{ d1time }}</span>
                            –
                            <span class="time-part">{{ d2time }}</span>
                          </span>
                        {%- else -%}
                          <span class="time-part">
                            <span class="time-part">{{ d1date }}</span>
                            <span class="time-part">{{ d1time }}</span>
                          </span>
                          –
                          <span class="time-part">
                            <span class="time-part">{{ d2date }}</span>
                            <span class="time-part">{{ d2time }}</span>
                          </span>
                        {%- endif -%}
                      {%- endif -%}
                      {%- if date_variants_available.size == 0 %}
                        <em>(sold out)</em>
                      {%- endif -%}
                    </label>
                  {%- else -%}
                    <label class="product-option">
                      <input
                        type="radio"
                        name="option-{{ option.name | handleize }}"
                        value="{{ value }}"
                        class="product-option__radio"
                        onchange="updateVariant()"
                        {% if forloop.first %}
                          checked
                        {% endif %}
                      >
                      {{ value }}
                    </label>
                  {%- endif -%}
                {%- endfor -%}
              </fieldset>
            {%- endfor -%}
            <input
              type="hidden"
              name="id"
              id="variant-id"
              value="{{ product.selected_or_first_available_variant.id }}"
            >
            <script id="variant-data" type="application/json">
              [
                {%- for variant in product.variants -%}
                  {
                    "id": {{ variant.id }},
                    "options": {{ variant.options | json }},
                    "price": {{ variant.price | money_without_trailing_zeros | json }},
                    "available": {{ variant.available | json }},
                    "inventory_quantity": {{ variant.inventory_quantity | json }}
                  }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
                ]
            </script>
            <script>
              function updateVariant() {
                const allRadios = document.querySelectorAll('.product-option__radio');
                const checkedRadios = document.querySelectorAll('.product-option__radio:checked:not([disabled])');
                const enabledRadios = document.querySelectorAll('.product-option__radio:not([disabled])');

                // Date-product detection: any label[data-date-end] means this product
                // exposes dates. We use that to distinguish "no dates left" from
                // "single-variant product with no option groups".
                const allDateLabels = document.querySelectorAll('label[data-date-end]');
                const visibleDateLabels = Array.from(allDateLabels).filter((l) => !l.hidden);

                const variantInput = document.getElementById('variant-id');
                const variantDataEl = document.getElementById('variant-data');
                const variants = JSON.parse(variantDataEl.textContent);
                const priceEl = document.querySelector('.product-price');
                const buyButton = document.getElementById('buy-button');
                const noDatesMsg = document.getElementById('product-no-dates');
                const quantityInput = document.getElementById('quantity');
                const quantityFormField = quantityInput?.closest('.product-option-group');
                const quantityAvailableValue = document.getElementById('quantity-available-value');

                const selectedOptions = Array.from(checkedRadios).map((r) => r.value);
                const variant = checkedRadios.length
                  ? variants.find((v) => selectedOptions.every((val, i) => val === v.options[i]))
                  : null;

                if (variant) {
                  variantInput.value = variant.id;
                  priceEl.textContent = variant.price;
                  const inventory = Number(variant.inventory_quantity) || 0;
                  if (quantityInput && quantityAvailableValue) {
                    quantityInput.min = Math.min(1, inventory);
                    quantityInput.max = inventory;
                    quantityAvailableValue.textContent = inventory;
                    if (parseInt(quantityInput.value, 10) > inventory) {
                      quantityInput.value = inventory;
                    }
                  }
                } else {
                  variantInput.value = '';
                }

                // Decide display state:
                //   no-dates   — this is a date product but every date is gone
                //   sold-out   — options exist, none are pickable (all disabled)
                //   unselected — options exist with available choices, user hasn't picked yet
                //   buy-now    — valid pick OR single-variant product with available stock
                let state;
                if (allDateLabels.length > 0 && visibleDateLabels.length === 0) {
                  state = 'no-dates';
                } else if (variant?.available) {
                  state = 'buy-now';
                } else if (allRadios.length === 0) {
                  // Single-variant product, no option groups. Liquid only renders
                  // the form when product.available is true, so trust that here.
                  state = 'buy-now';
                } else if (enabledRadios.length === 0) {
                  state = 'sold-out';
                } else if (checkedRadios.length === 0) {
                  state = 'unselected';
                } else {
                  // Picked variant exists but isn't available (e.g. inventory hit 0).
                  state = 'sold-out';
                }

                if (noDatesMsg) noDatesMsg.hidden = state !== 'no-dates';
                buyButton.hidden = state === 'no-dates' || state === 'unselected';
                if (!buyButton.hidden) {
                  buyButton.disabled = state !== 'buy-now';
                  buyButton.textContent =
                    state === 'buy-now' ? buyButton.dataset.textAvailable : buyButton.dataset.textSoldOut;
                }
                if (quantityFormField) quantityFormField.hidden = state !== 'buy-now';
              }
            </script>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endif -%}

          {% if product.selected_or_first_available_variant.inventory_management %}
            <div class="product-option-group">
              <label
                for="quantity"
                class="product-option-group__legend"
              >
                {{- 'products.product.quantity' | t -}}
              </label>
              <input
                type="number"
                id="quantity"
                name="quantity"
                value="1"
                min="1"
                max="{{ product.selected_or_first_available_variant.inventory_quantity }}"
                class="product-quantity__value"
                required
                aria-describedby="quantity-available"
              >
              <span id="quantity-available" class="product-quantity__available">
                (
                {%- assign count = '<span id="quantity-available-value">'
                  | append: product.selected_or_first_available_variant.inventory_quantity
                  | append: '</span>'
                -%}
                {{- 'products.product.quantity_available' | t: count: '__COUNT__' | replace: '__COUNT__', count -}}
                )
              </span>
            </div>
          {% endif %}
          <input type="hidden" name="return_to" value="/checkout" id="return-to">
          <p id="product-no-dates" class="product-no-dates" hidden>No dates at the moment.</p>
          <button
            type="submit"
            class="product-buy-button"
            id="buy-button"
            data-text-available="{{ 'products.product.buy_now' | t }}"
            data-text-sold-out="{{ 'products.product.sold_out' | t }}"
          >
            {{ 'products.product.buy_now' | t }}
          </button>
        </fieldset>
      </form>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const fieldset = document.getElementById('product-form-fieldset');
          const form = document.getElementById('product-form');

          // Date-radio housekeeping (past-date hiding, calendar widget) runs
          // in assets/product-date-calendar.js before this listener fires.

          if (typeof updateVariant === 'function') {
            updateVariant();
          }
          if (fieldset) fieldset.disabled = false;

          // Clear cart before adding product and going to checkout
          if (form) {
            form.addEventListener('submit', async (e) => {
              e.preventDefault();

              if (!form.checkValidity()) {
                form.reportValidity();
                return;
              }

              try {
                // Clear the cart first
                await fetch('/cart/clear.js', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                  },
                });
              } catch (_error) {}

              try {
                // Then submit the form normally
                e.target.submit();
              } catch (error) {
                console.error('Error clearing cart:', error);
                // Submit anyway if clearing fails
                e.target.submit();
              }
            });
          }
        });
      </script>
    {%- endif -%}
  </div>
</div>
